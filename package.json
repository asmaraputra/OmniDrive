{
  "name": "omnidrive",
  "version": "0.9.7",
  "description": "Unified multi-Google Drive storage gateway built on Cloudflare Workers",
  "private": true,
  "license": "MIT",
  "author": "abilfida",
  "repository": {
    "type": "git",
    "url": "https://github.com/abilfida/omnidrive.git"
  },
  "workspaces": [
    "packages/worker",
    "packages/web"
  ],
  "scripts": {
    "dev:worker": "npm run dev -w packages/worker",
    "dev:web": "npm run dev -w packages/web",
    "dev": "concurrently \"npm run dev:worker\" \"npm run dev:web\"",
    "build:worker": "npm run build -w packages/worker",
    "build:web": "npm run build -w packages/web",
    "test": "npm run test -w packages/worker",
    "deploy:worker": "npm run deploy -w packages/worker",
    "deploy:web": "npm run build:web && npm run deploy -w packages/web",
    "deploy:code": "npm run deploy:worker && npm run deploy:web",
    "migrate:remote": "npm run db:migrate:remote -w packages/worker",
    "deploy:full": "npm run migrate:remote && npm run deploy:code"
  },
  "devDependencies": {
    "@clack/prompts": "^1.5.1",
    "concurrently": "^9.1.0",
    "dotenv": "^17.4.2",
    "picocolors": "^1.1.1",
    "typescript": "^5.7.0"
  }
}
